# ===========================================
# 链上套利助手 - 环境变量配置模板
# ===========================================
# 复制此文件为 .env 并填写实际值

# ===========================================
# 飞书机器人配置
# ===========================================
# 飞书 Webhook 地址 (必填)
# 获取方式: 飞书群 -> 设置 -> 群机器人 -> 添加机器人 -> 自定义机器人
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-url-here

# 飞书签名密钥 (可选，推荐启用)
# 用于增强安全性，防止他人伪造消息
# 设置方式: 在飞书机器人设置中开启签名验证并设置密钥
FEISHU_SECRET=

# 是否启用飞书通知
# true = 启用, false = 禁用
FEISHU_ENABLED=true

# 飞书机器人名称 (可选)
FEISHU_BOT_NAME=套利助手

# ===========================================
# Telegram Bot 配置 (可选)
# ===========================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ALERT_ENABLED=false

# ===========================================
# RPC 节点配置 (可选，通常使用代码中的默认配置)
# ===========================================
# ETH_RPC_URL=https://eth.llamarpc.com
# BSC_RPC_URL=https://bsc.publicnode.com
# ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc

# ===========================================
# API Keys (可选)
# ===========================================
# 1inch API (用于获取最优交易路径)
# 申请地址: https://portal.1inch.dev/
INCH_API_KEY=

# CoinGecko API (用于获取代币 USD 价格)
# 免费版: https://www.coingecko.com/
# 专业版: https://pro.coingecko.com/
COINGECKO_API_KEY=

# ===========================================
# Redis 配置 (可选)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# ===========================================
# 日志配置
# ===========================================
LOG_LEVEL=INFO
# LOG_FILE=logs/app.log
